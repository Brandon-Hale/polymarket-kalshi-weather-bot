# =============================================================================
# Trading Bot Configuration — example. Copy to .env and fill in values.
# =============================================================================

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
DATABASE_URL=sqlite:///./tradingbot.db
# DATABASE_URL=postgresql://user:pass@localhost/tradingbot

# -----------------------------------------------------------------------------
# Mode + bankroll
# -----------------------------------------------------------------------------
# SIMULATION_MODE=true  → no real money, bankroll comes from INITIAL_BANKROLL.
# SIMULATION_MODE=false → live mode (requires all four POLYMARKET_* creds below).
SIMULATION_MODE=true
INITIAL_BANKROLL=1000

# Sizing
KELLY_FRACTION=0.15            # Fractional Kelly (lower = more conservative)
MAX_TRADE_BANKROLL_FRACTION=0.05  # Hard cap per trade = 5% of bankroll
MAX_TRADE_SIZE=5000.0          # Absolute dollar cap (binds at high bankroll)

# -----------------------------------------------------------------------------
# Per-market trading switches — control whether trades are PLACED.
# Signal scanning + dashboard display continue regardless.
# Flip to false to silence a stream.
# -----------------------------------------------------------------------------
BTC_TRADING_ENABLED=true
WEATHER_TRADING_ENABLED=true

# -----------------------------------------------------------------------------
# BTC 5-min strategy thresholds
# -----------------------------------------------------------------------------
MIN_EDGE_THRESHOLD=0.02        # 2% — BTC markets are near-coinflip
MAX_ENTRY_PRICE=0.55           # Don't pay more than 55c per share
BTC_MAX_TRADES_PER_SCAN=10     # Max new BTC trades per 1-min scan
BTC_MAX_TOTAL_ALLOCATION=1000  # Max aggregate open BTC notional ($)

# -----------------------------------------------------------------------------
# Weather strategy thresholds
# -----------------------------------------------------------------------------
WEATHER_ENABLED=true
WEATHER_MIN_EDGE_THRESHOLD=0.08
WEATHER_MAX_ENTRY_PRICE=0.70
WEATHER_MIN_VOLUME=1000.0          # Skip illiquid buckets
WEATHER_MAX_TRADES_PER_SCAN=10     # Max new weather trades per 5-min scan
WEATHER_MAX_TOTAL_ALLOCATION=10000 # Max aggregate open weather notional ($)

# -----------------------------------------------------------------------------
# Polymarket LIVE trading (only used when SIMULATION_MODE=false)
# See SETUP_LIVE.md for how to obtain these.
# -----------------------------------------------------------------------------
# Path A — existing Polymarket account (email login / Magic wallet):
#   Set both POLYMARKET_PRIVATE_KEY (the exported signer key) AND
#   POLYMARKET_FUNDER_ADDRESS (your proxy address that holds the USDC).
# Path B — fresh EOA wallet (MetaMask):
#   Set POLYMARKET_PRIVATE_KEY only. Leave POLYMARKET_FUNDER_ADDRESS empty.
POLYMARKET_PRIVATE_KEY=
POLYMARKET_FUNDER_ADDRESS=

# API credentials — generate in polymarket.com → Settings → API
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=

# Live-mode safety caps — start TIGHT, raise after you confirm fills work.
LIVE_TRADE_MAX_USD=5.0           # Hard cap per individual live order
LIVE_TRADE_DAILY_USD_LIMIT=25.0  # Halt new orders once today's notional hits this

# -----------------------------------------------------------------------------
# Kalshi (disabled in this build — kept for back-compat, ignore)
# -----------------------------------------------------------------------------
KALSHI_API_KEY_ID=
KALSHI_PRIVATE_KEY_PATH=
KALSHI_ENABLED=false

# -----------------------------------------------------------------------------
# Misc / optional
# -----------------------------------------------------------------------------
GROQ_API_KEY=
VITE_MAPBOX_TOKEN=
