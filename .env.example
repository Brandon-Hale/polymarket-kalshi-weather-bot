# =============================================================================
# Trading Bot — example. Copy to .env and fill in values.
# Only put values here that you need to override per-environment.
# All tuning defaults (Kelly fraction, edge thresholds, allocation caps, etc.)
# live in backend/config.py and don't need to be set here.
# =============================================================================

# -----------------------------------------------------------------------------
# Mode + per-strategy toggles
# -----------------------------------------------------------------------------
# SIMULATION_MODE=true  → paper trading from INITIAL_BANKROLL.
# SIMULATION_MODE=false → live trading (requires Polymarket creds below).
SIMULATION_MODE=true
INITIAL_BANKROLL=1000

# Disable a strategy's trade placement without stopping its scans/dashboard.
BTC_TRADING_ENABLED=true
WEATHER_TRADING_ENABLED=true

# -----------------------------------------------------------------------------
# Polymarket live trading (used only when SIMULATION_MODE=false)
# See SETUP_LIVE.md for the step-by-step on obtaining each.
# -----------------------------------------------------------------------------
# Wallet — signer private key. Path A users: also set FUNDER_ADDRESS below.
POLYMARKET_PRIVATE_KEY=
POLYMARKET_FUNDER_ADDRESS=

# CLOB API credentials (from polymarket.com → Settings → API)
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=

# Live-mode safety caps — start tight.
LIVE_TRADE_MAX_USD=5.0
LIVE_TRADE_DAILY_USD_LIMIT=25.0

# -----------------------------------------------------------------------------
# Frontend
# -----------------------------------------------------------------------------
VITE_MAPBOX_TOKEN=
